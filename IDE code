#include <WiFi.h>
#include <ThingSpeak.h>

// Pin Definitions
#define TRIG_PIN 23
#define ECHO_PIN 22
#define LDR_PIN 34
#define GAS_PIN 35
#define MOTION_PIN 21
#define BUZZER_PIN 19

// ThingSpeak API details
const char* ssid = "YOUR_SSID"; // Enter your Wi-Fi SSID
const char* password = "YOUR_PASSWORD"; // Enter your Wi-Fi password
WiFiClient client;
unsigned long myChannelNumber = YOUR_CHANNEL_ID; // Replace with your channel ID
const char* myWriteAPIKey = "YOUR_WRITE_API_KEY"; // Replace with your ThingSpeak API key

// Thresholds for sensors
int gasThreshold = 400; // Example threshold for gas level (adjust based on sensor calibration)
int lightThreshold = 500; // Example threshold for LDR (darkness)

// Timing for ThingSpeak updates
unsigned long lastTime = 0;
unsigned long timerDelay = 15000; // Update every 15 seconds

void setup() {
  Serial.begin(115200);
  
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(MOTION_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  // Start Wi-Fi connection
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(1000);
    Serial.println("Connecting to WiFi...");
  }
  Serial.println("Connected to WiFi!");

  // Initialize ThingSpeak connection
  ThingSpeak.begin(client);
}

void loop() {
  long distance = getUltrasonicDistance();
  int ldrValue = analogRead(LDR_PIN);
  int gasValue = analogRead(GAS_PIN);
  int motionDetected = digitalRead(MOTION_PIN);

  // Print sensor values to Serial Monitor
  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.print(" cm, LDR: ");
  Serial.print(ldrValue);
  Serial.print(", Gas Level: ");
  Serial.print(gasValue);
  Serial.print(", Motion Detected: ");
  Serial.println(motionDetected);

  // Parking Spot Occupancy (based on ultrasonic sensor)
  bool isSpotOccupied = (distance < 20);  // If distance is less than 20 cm, spot is considered occupied
  if (isSpotOccupied) {
    Serial.println("Parking Spot Occupied");
  } else {
    Serial.println("Parking Spot Free");
  }

  // LDR sensor: If light is low, notify (optional functionality)
  if (ldrValue < lightThreshold) {
    Serial.println("Low Light Detected");
  }

  // Gas sensor: If gas value is high, trigger alert (optional functionality)
  if (gasValue > gasThreshold) {
    Serial.println("Warning: High Gas Levels Detected!");
  }

  // Motion detection with buzzer alert
  if (motionDetected == HIGH) {
    digitalWrite(BUZZER_PIN, HIGH); // Turn on buzzer when motion is detected
    delay(1000); // Buzzer on for 1 second
    digitalWrite(BUZZER_PIN, LOW);  // Turn off buzzer
    Serial.println("Motion Detected, Buzzer Activated");
  }

  // Send data to ThingSpeak every 15 seconds
  unsigned long currentMillis = millis();
  if (currentMillis - lastTime > timerDelay) {
    lastTime = currentMillis;

    // Send sensor data to ThingSpeak
    ThingSpeak.setField(1, distance);     // Send distance (occupancy) data
    ThingSpeak.setField(2, ldrValue);     // Send LDR data (light intensity)
    ThingSpeak.setField(3, gasValue);     // Send gas data (hazardous gases)
    ThingSpeak.setField(4, motionDetected); // Send motion detection status (0 or 1)

    // Update ThingSpeak
    ThingSpeak.writeFields(myChannelNumber, myWriteAPIKey);
    Serial.println("Data sent to ThingSpeak");
  }

  delay(1000);  // Delay to avoid spamming the serial monitor
}

// Function to measure distance using Ultrasonic Sensor
long getUltrasonicDistance() {
  // Send pulse to trigger
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  // Measure the pulse duration
  long duration = pulseIn(ECHO_PIN, HIGH);

  // Calculate the distance in centimeters
  long distance = duration * 0.034 / 2;
  return distance;
}
